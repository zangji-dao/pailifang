{
  "apps": [
    {
      "name": "pi-cube",
      "script": "pnpm",
      "args": "run start",
      "cwd": "/var/www/pi-cube",
      "instances": 1,
      "exec_mode": "fork",
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "error_file": "/var/www/pi-cube/logs/pm2-error.log",
      "out_file": "/var/www/pi-cube/logs/pm2-out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z"
    }
  ]
}
