# Π立方会计系统 - 后端环境变量配置
# 复制此文件为 .env 并填写实际值

# ===========================================
# 数据库配置
# ===========================================
PG_HOST=152.136.12.122
PG_PORT=5432
PG_USER=pi_user
PG_PASSWORD=your_password_here
PG_DATABASE=pi_cube

# ===========================================
# 服务配置
# ===========================================
PORT=4001
NODE_ENV=development

# ===========================================
# 对象存储配置（腾讯云 COS）
# ===========================================
# 访问密钥（从 https://console.cloud.tencent.com/cam/capi 获取）
S3_ACCESS_KEY_ID=your_secret_id_here
S3_SECRET_ACCESS_KEY=your_secret_key_here

# 存储桶配置
S3_BUCKET=pi-cube-files-1234567890
S3_REGION=ap-beijing

# 端点地址（根据地域不同）
# 北京：https://cos.ap-beijing.myqcloud.com
# 上海：https://cos.ap-shanghai.myqcloud.com
# 广州：https://cos.ap-guangzhou.myqcloud.com
S3_ENDPOINT=https://cos.ap-beijing.myqcloud.com

# ===========================================
# 支付宝配置
# ===========================================
ALIPAY_APPID=your_appid
ALIPAY_PRIVATE_KEY=your_private_key
ALIPAY_PUBLIC_KEY=your_public_key
ALIPAY_REDIRECT_URI=https://pi.chemicaloop.com/api/alipay/callback
