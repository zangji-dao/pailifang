# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# PostgreSQL 数据库配置（开发环境和生产环境共用）
PG_HOST=152.136.12.122
PG_PORT=5432
PG_USER=pi_user
PG_PASSWORD=your_password_here
PG_DATABASE=pi_cube

# 支付宝开放平台配置
ALIPAY_APPID=your_appid_here
ALIPAY_PRIVATE_KEY=your_private_key_here
ALIPAY_PUBLIC_KEY=alipay_public_key_here

# 支付宝授权回调地址
# 开发环境：使用内网穿透地址
# 生产环境：https://pi.chemicaloop.com/api/alipay/callback
ALIPAY_REDIRECT_URI=https://pi.chemicaloop.com/api/alipay/callback

# 高德地图配置
# 获取 API Key: https://lbs.amap.com/api/javascript-api/guide/abc/prepare
AMAP_KEY=your_amap_key_here
